DEFINE CLASS frmfixdbc AS sfform OF "..\..\sfcommon\sfctrls.vcx" 
 	*< CLASSDATA: Baseclass="form" Timestamp="" Scale="" Uniqueid="" />

	*-- OBJECTDATA items order determines ZOrder / El orden de los items OBJECTDATA determina el ZOrder 
	*< OBJECTDATA: ObjPath="oTree" UniqueID="" Timestamp="" />
	*< OBJECTDATA: ObjPath="edtValue" UniqueID="" Timestamp="" />
	*< OBJECTDATA: ObjPath="lblValue" UniqueID="" Timestamp="" />
	*< OBJECTDATA: ObjPath="oImageList" UniqueID="" Timestamp="" />
	*< OBJECTDATA: ObjPath="lblComment" UniqueID="" Timestamp="" />
	*< OBJECTDATA: ObjPath="cmdUpdate" UniqueID="" Timestamp="" />
	*< OBJECTDATA: ObjPath="cmdCancel" UniqueID="" Timestamp="" />

	*<DefinedPropArrayMethod>
		*m: decimal2hex		&& Converts a decimal value to a hex value
		*m: findobjectindbc		&& Finds the record for the specified object in the DBC
		*m: getcurrentproperty		&& Gets the value of the selected property
		*m: getfieldsorindexesfortable		&& Fills the passed array with fields or indexes for the specified table
		*m: getproperty		&& Gets the specified property from the PROPERTY memo
		*m: hex2decimal		&& Converts a hex value to a decimal value
		*m: loadconnection		&& Loads the specified connection into the TreeView
		*m: loadfieldorindex		&& Loads the specified field or index into the TreeView
		*m: loadproperties		&& Load the TreeView with properties for the specified object
		*m: loadrelation		&& Loads the specified relation into the TreeView
		*m: loadtable		&& Loads the TreeView with nodes for the specified table or view
		*m: loadtree		&& Loads the tree with records from the database
		*m: reversedecimal2hex		&& Converts decimal to hex in reverse order
		*m: reversehex2decimal		&& Converts hex (in reverse order) to decimal
		*m: setcurrentproperty		&& Sets the value for the currently selected property
		*m: setproperty		&& Saves the value for the specified property
		*p: cdbcalias		&& The alias the DBC is opened with
	*</DefinedPropArrayMethod>

	*<PropValue>
		Caption = "DBC Properties Repair Utility"
		cdbcalias = 
		DoCreate = .T.
		Height = 370
		Name = "frmFixDBC"
		Width = 560
	*</PropValue>

	ADD OBJECT 'cmdCancel' AS sfcommandbutton WITH ;
		Caption = "Cancel", ;
		FontName = "Tahoma", ;
		Left = 412, ;
		Name = "cmdCancel", ;
		TabIndex = 7, ;
		Top = 165
		*< END OBJECT: ClassLib="..\..\sfcommon\sfctrls.vcx" BaseClass="commandbutton" />

	ADD OBJECT 'cmdUpdate' AS sfcommandbutton WITH ;
		Caption = "Save", ;
		FontName = "Tahoma", ;
		Left = 322, ;
		Name = "cmdUpdate", ;
		TabIndex = 6, ;
		Top = 165
		*< END OBJECT: ClassLib="..\..\sfcommon\sfctrls.vcx" BaseClass="commandbutton" />

	ADD OBJECT 'edtValue' AS sfeditbox WITH ;
		Enabled = .F., ;
		FontName = "Tahoma", ;
		Height = 78, ;
		Left = 270, ;
		Name = "edtValue", ;
		TabIndex = 4, ;
		Top = 30, ;
		Width = 280
		*< END OBJECT: ClassLib="..\..\sfcommon\sfctrls.vcx" BaseClass="editbox" />

	ADD OBJECT 'lblComment' AS sflabel WITH ;
		AutoSize = .F., ;
		Caption = "Comment", ;
		FontName = "Tahoma", ;
		Height = 30, ;
		Left = 270, ;
		Name = "lblComment", ;
		TabIndex = 5, ;
		Top = 115, ;
		Width = 280, ;
		WordWrap = .T.
		*< END OBJECT: ClassLib="..\..\sfcommon\sfctrls.vcx" BaseClass="label" />

	ADD OBJECT 'lblValue' AS sflabel WITH ;
		Caption = "Property value", ;
		FontName = "Tahoma", ;
		Left = 270, ;
		Name = "lblValue", ;
		TabIndex = 3, ;
		Top = 10
		*< END OBJECT: ClassLib="..\..\sfcommon\sfctrls.vcx" BaseClass="label" />

	ADD OBJECT 'oImageList' AS olecontrol WITH ;
		Height = 21, ;
		Left = 270, ;
		Name = "oImageList", ;
		Top = 270, ;
		Width = 51
		*< END OBJECT: BaseClass="olecontrol" OLEObject="c:\windows\system32\mscomctl.ocx" Value="" />

	ADD OBJECT 'oTree' AS olecontrol WITH ;
		Height = 350, ;
		Left = 10, ;
		Name = "oTree", ;
		TabIndex = 1, ;
		Top = 10, ;
		Width = 250
		*< END OBJECT: BaseClass="olecontrol" OLEObject="c:\windows\system32\mscomctl.ocx" Value="" />
	
	PROCEDURE decimal2hex		&& Converts a decimal value to a hex value
		lparameters tnValue, ;
			tnPlaces
		local lnPlaces, ;
			lcHex, ;
			lcOut, ;
			lnI
		lnPlaces = iif(pcount() = 1, 4, tnPlaces)
		lcHex    = This.ReverseDecimal2Hex(tnValue, lnPlaces)
		lcOut    = ''
		for lnI = 1 to lnPlaces
			lcOut = lcOut + substr(lcHex, lnPlaces - lnI + 1, 1)
		next lnI
		return lcOut
		
	ENDPROC

	PROCEDURE Destroy
		* Close the tables we opened.
		
		use in select(This.cDBCAlias)
		use in select('PROPS')
		
	ENDPROC

	PROCEDURE findobjectindbc		&& Finds the record for the specified object in the DBC
		lparameters tcObjectName, ;
			tcObjectType
		local lnSelect, ;
			lcObjectType, ;
			lcAlias, ;
			lcObject, ;
			lnReturn
		with This
			lnSelect = select()
			select (.cDBCAlias)
		
		* If the object name has an alias, let's split the name into alias and object.
		
			lcObjectType = padr(proper(tcObjectType),   fsize('OBJECTTYPE'))
			if '.' $ tcObjectName
				lcAlias  = padr(juststem(tcObjectName), fsize('OBJECTNAME'))
				lcObject = padr(justext(tcObjectName),  fsize('OBJECTNAME'))
			else
				lcObject = padr(tcObjectName, fsize('OBJECTNAME'))
			endif '.' $ tcObjectName
			if lcObjectType = 'Database'
				lcObject = ''
			endif lcObjectType = 'Database'
			do case
		
		* Look for a database, table, view, or connection by SEEKing for the object
		* with the database as the parent.
		
				case inlist(trim(lcObjectType), 'Database', 'Table', 'View', ;
					'Connection')
					= seek(str(1) + lcObjectType + lcObject, alias(), ;
						'OBJECTNAME')
		
		* Look for an index by finding the parent table first, then using it to find
		* the object.
		
				case inlist(trim(lcObjectType), 'Index', 'Relation')
					= seek(str(1) + padr('Table', fsize('OBJECTTYPE')) + ;
						lcAlias, alias(), 'OBJECTNAME') and ;
						seek(str(OBJECTID) + lcObjectType + lcObject, alias(), ;
						'OBJECTNAME')
		
		* Look for a field by finding the parent (which could be a table or a view)
		* first, then using it to find the object.
		
				case trim(lcObjectType) == 'Field'
					= (seek(str(1) + padr('Table', fsize('OBJECTTYPE')) + ;
						lcAlias, alias(), 'OBJECTNAME') or ;
						seek(str(1) + padr('View', fsize('OBJECTTYPE')) + lcAlias, ;
						alias(), 'OBJECTNAME')) and ;
						seek(str(OBJECTID) + lcObjectType + lcObject, alias(), ;
						'OBJECTNAME')
		
		* Look for a relation by finding the parent table first, then using it to find
		* the object, then looking for the relation record with the desired properties.
		
				case inlist(trim(lcObjectType), 'Index', 'Relation') and ;
					seek(str(1) + padr('Table', fsize('OBJECTTYPE')) + ;
						lcAlias, alias(), 'OBJECTNAME')
					lnPos       = at(',', tcObjectName)
					lcChildTag  = justext(left(tcObjectName, lnPos - 1))
					lcParent    = substr(tcObjectName, lnPos + 1)
					lcParentTag = justext(lcParent)
					lcParent    = juststem(lcParent)
					lnObjectID  = OBJECTID
					locate for OBJECTID = lnObjectID and lcChildTag $ PROPERTY and ;
						lcParent $ PROPERTY and lcChildTag $ PROPERTY
			endcase
			lnReturn = OBJECTID
			select (lnSelect)
		endwith
		return lnReturn
		
	ENDPROC

	PROCEDURE getcurrentproperty		&& Gets the value of the selected property
		lparameters toNode
		local lcKey, ;
			lnPos, ;
			lcType, ;
			lcObject, ;
			lcProperty, ;
			lcValue
		with This
			lcKey = toNode.Key
		
		* If this is a property node, figure out which property for which object.
		
			if left(lcKey, 1) = 'P'
				lcKey      = substr(lcKey, 2)
				lnPos      = at('/', lcKey, 1)
				lcType     = left(lcKey, lnPos - 1)
				lcKey      = substr(lcKey, lnPos + 1)
				lnPos      = at('/', lcKey)
				lcObject   = left(lcKey, lnPos - 1)
				lcProperty = substr(lcKey, lnPos + 1)
		
		* Find the record for the object in the DBC, then get the value of the
		* specified property.
		
				.FindObjectInDBC(lcObject, lcType)
				= seek(padr(lcType, len(PROPS.TYPE)) + lcProperty, 'PROPS', ;
					'PROPERTY')
				lcValue = .GetProperty(PROPS.ID, PROPS.BINARY)
		
		* Update the controls. Limit the length of the property to 254 for all
		* properties but SQL.
		
				.edtValue.Enabled   = .T.
				.edtValue.Value     = lcValue
				.edtValue.MaxLength = iif(PROPS.ID = 42, 0, 254)
				.lblComment.Caption = PROPS.COMMENT
				.cmdUpdate.Enabled  = .T.
				.cmdCancel.Enabled  = .T.
			else
				.edtValue.Enabled   = .F.
				.edtValue.Value     = ''
				.lblComment.Caption = ''
				.cmdUpdate.Enabled  = .F.
				.cmdCancel.Enabled  = .F.
			endif left(lcKey, 1) = 'P'
		endwith
		
	ENDPROC

	PROCEDURE getfieldsorindexesfortable		&& Fills the passed array with fields or indexes for the specified table
		lparameters tcTable, ;
			tcType, ;
			tcItemType, ;
			taArray
		local lnObject, ;
			lnFields
		with This
			lnObject = .FindObjectInDBC(tcTable, tcType)
			select OBJECTNAME ;
				from (.cDBCAlias) ;
				where PARENTID = lnObject and OBJECTTYPE = tcItemType ;
				into array taArray
			lnItems = _tally
			for lnI = 1 to lnItems
				taArray[lnI] = tcTable + '.' + trim(taArray[lnI])
			next lnI
		endwith
		return lnItems
		
	ENDPROC

	PROCEDURE getproperty		&& Gets the specified property from the PROPERTY memo
		lparameters tnID, ;
			tlBinary
		local lnSelect, ;
			lcReturn, ;
			llDone, ;
			lnPos, ;
			lcLength, ;
			lnLength, ;
			lnIDLength, ;
			lnIDCode
		with This
			lnSelect = select()
			select (.cDBCAlias)
		
		* Try to locate the desired property by looking at all properties one at a
		* time until we find it.
		
			lcReturn = ''
			llDone   = .F.
			lnPos    = 1
			do while not llDone
		
		* Get the length of this property.
		
				lcLength = substr(PROPERTY, lnPos, 4)
				lnLength = .Hex2Decimal(lcLength)
		
		* Get the length of the property ID.
		
				lcLength   = substr(PROPERTY, lnPos + 4, 2)
				lnIDLength = .Hex2Decimal(lcLength)
		
		* Get the property ID.
		
				lcLength = substr(PROPERTY, lnPos + 6, lnIDLength)
				lnIDCode = .Hex2Decimal(lcLength)
		
		* If this is the property we want, get the value and strip off the trailing
		* null if there is one.
		
				if lnIDCode = tnID
					lcReturn = substr(PROPERTY, lnPos + lnIDLength + 6, ;
						lnLength - lnIDLength - 6)
					lcReturn = iif(not tlBinary and right(lcReturn, 1) = chr(0), ;
						left(lcReturn, len(lcReturn) - 1), lcReturn)
		
		* See if the property is damaged.
		
					if not tlBinary
						lcValue = substr(PROPERTY, lnPos + lnIDLength + 6)
						lcValue = left(lcValue, at(chr(0), lcValue) - 1)
						if len(lcReturn) <> len(lcValue)
							messagebox("This property's actual length doesn't " + ;
								"match the length stored in the DBC.", 16, .Caption)
							lcReturn = lcValue
						endif
					endif not tlBinary
					llDone = .T.
		
		* Move the pointer to the next property. If we're out of properties, we're
		* done checking.
		
				else
					lnPos = lnPos + lnLength
					if lnPos > len(PROPERTY)
						lcReturn = .NULL.
						llDone   = .T.
					endif lnPos > len(PROPERTY)
				endif lnIDCode = tnID
			enddo while not llDone
		
		* Convert the value if necessary.
		
			if not isnull(lcReturn) and tlBinary
				lcReturn = transform(.ReverseHex2Decimal(lcReturn, .T.))
			endif not isnull(lcReturn) ...
			select (lnSelect)
		endwith
		return lcReturn
		
	ENDPROC

	PROCEDURE hex2decimal		&& Converts a hex value to a decimal value
		lparameters tcValue, ;
			tlSigned
		local lnDecimal, ;
			lnLen, ;
			lnI, ;
			lnMSB, ;
			lnMax
		lnDecimal = 0
		lnLen     = len(tcValue)
		for lnI = 1 to lnLen
			lnDecimal = lnDecimal + asc(substr(tcValue, lnI, 1)) * 256 ^ (lnI - 1)
		next lnI
		if tlSigned
			lnMSB = (lnLen * 8) - 1
			if bittest(lnDecimal, lnMSB)
				lnMax     = 2 ^ (lnMSB + 1)
				lnDecimal = lnDecimal - lnMax
			endif bittest(lnDecimal, lnMSB)
		endif tlSigned
		return lnDecimal
		
	ENDPROC

	PROCEDURE Init
		* If we don't have an open database, tell the user and exit.
		
		local lcPath
		with This
			if empty(dbc())
				messagebox('Please open a database before running FixDBC.', 16, .Caption)
				return .F.
			endif empty(dbc())
		
		* Open the DBC as a table.
		
			.cDBCAlias = sys(2015)
			use (dbc()) again in 0 shared alias (.cDBCAlias)
		
		* Open the PROPS table.
		
			if not used('PROPS')
				lcPath = sys(16)
				lcPath = addbs(justpath(substr(lcPath, at(' ', lcPath, 2) + 1)))
				use (lcPath + 'PROPS') again in 0 shared
			endif not used('PROPS')
			set order to PROPERTY in PROPS
		
		* Load the TreeView.
		
			.oTree.ImageList = .oImageList.Object
			.LoadTree()
		endwith
		
	ENDPROC

	PROCEDURE loadconnection		&& Loads the specified connection into the TreeView
		lparameters tcConnection, ;
			tcParentKey
		local lcObject, ;
			lcKey
		with This
			lcObject = lower(tcConnection)
			lcKey    = 'C' + strtran(lcObject, ' ', '_')
			.oTree.Nodes.Add(tcParentKey, 4, lcKey, lcObject, 'Connection')
			.LoadProperties(lcKey, 'Connection')
		endwith
		
	ENDPROC

	PROCEDURE loadfieldorindex		&& Loads the specified field or index into the TreeView
		lparameters tcObject, ;
			tcType, ;
			tcParentKey, ;
			tcParentType
		local lcObject, ;
			lcKey
		with This
			lcObject = lower(justext(tcObject))
			lcKey    = left(tcType, 1) + strtran(tcObject, ' ', '_')
			.oTree.Nodes.Add(tcParentKey, 4, lcKey, lcObject, tcType)
			.LoadProperties(lcKey, tcType, tcParentType)
		endwith
		
	ENDPROC

	PROCEDURE loadproperties		&& Load the TreeView with properties for the specified object
		lparameters tcParentKey, ;
			tcType, ;
			tcParentType
		local lnSelect, ;
			lcPropsKey, ;
			lcProperty, ;
			lcKey
		with This
			lnSelect = select()
			if tcType $ 'Table,Database,View'
				lcPropsKey = sys(2015)
				.oTree.Nodes.Add(tcParentKey, 4, lcPropsKey, 'Properties', 'Property')
			else
				lcPropsKey = tcParentKey
			endif tcType $ 'Table,Database,View'
			select PROPS
			scan for TYPE = tcTYPE and (empty(SUBTYPE) or (not empty(tcParentType) and ;
				SUBTYPE = tcParentType))
				lcProperty = trim(PROPERTY)
				lcKey      = 'P' + tcType + '/' + ;
					iif(tcType = 'Database', tcParentKey, substr(tcParentKey, 2)) + ;
					'/' + lcProperty
				.oTree.Nodes.Add(lcPropsKey, 4, lcKey, lcProperty, 'Property')
			endscan for TYPE = tcTYPE ...
			select (lnSelect)
		endwith
		
	ENDPROC

	PROCEDURE loadrelation		&& Loads the specified relation into the TreeView
		lparameters tcChild, ;
			tcParent, ;
			tcChildTag, ;
			tcParentTag, ;
			tcParentKey
		local lcObject, ;
			lcKey
		with This
			lcObject = lower(tcChild + '.' + tcChildTag + ',' + tcParent + '.' + ;
				tcParentTag)
			lcKey    = 'R' + strtran(lcObject, ' ', '_')
			.oTree.Nodes.Add(tcParentKey, 4, lcKey, lcObject, 'Relation')
			.LoadProperties(lcKey, 'Relation')
		endwith
		
	ENDPROC

	PROCEDURE loadtable		&& Loads the TreeView with nodes for the specified table or view
		lparameters tcTable, ;
			tcType, ;
			tcParentKey
		local lcTable, ;
			lcKey, ;
			lcFieldsKey, ;
			laFields[1], ;
			lnFields, ;
			lnI, ;
			laIndexes[1], ;
			lnIndexes, ;
			lcIndexesKey, ;
			laRelations[1], ;
			lnRelations, ;
			lnRelation, ;
			lcRelationsKey
		with This
			lcTable = lower(tcTable)
			lcKey   = left(tcType, 1) + strtran(lcTable, ' ', '_')
			.oTree.Nodes.Add(tcParentKey, 4, lcKey, lcTable, tcType)
			.LoadProperties(lcKey, tcType)
		
		* Get the fields for the table/view and add nodes for them.
		
			lcFieldsKey = sys(2015)
			.oTree.Nodes.Add(lcKey, 4, lcFieldsKey, 'Fields', 'Field')
			lnFields = .GetFieldsOrIndexesForTable(lcTable, tcType, 'Field', @laFields)
			for lnI = 1 to lnFields
				.LoadFieldOrIndex(laFields[lnI], 'Field', lcFieldsKey, tcType)
			next lnI
		
		* If this is a table, handle indexes and relations as well.
		
			if tcType = 'Table'
				lnIndexes = .GetFieldsOrIndexesForTable(lcTable, tcType, 'Index', ;
					@laIndexes)
				if lnIndexes > 0
					lcIndexesKey = sys(2015)
					.oTree.Nodes.Add(lcKey, 4, lcIndexesKey, 'Indexes', 'Index')
					for lnI = 1 to lnIndexes
						.LoadFieldOrIndex(laIndexes[lnI], 'Index', lcIndexesKey)
					next lnI
				endif lnIndexes > 0
		
		* Get the relations for the table and add nodes for them.
		
		*** This is commented out for now since the only properties for relations are
		*** those that ADBOBJECTS() returns
		*!*			lnRelations = adbobjects(laRelations, 'Relation')
		*!*			lnRelation  = 0
		*!*			for lnI = 1 to lnRelations
		*!*				if lower(laRelations[lnI, 1]) == lcTable
		*!*					if lnRelation = 0
		*!*						lcRelationsKey = sys(2015)
		*!*						.oTree.Nodes.Add(lcKey, 4, lcRelationsKey, 'Relations', ;
		*!*							'Relation')
		*!*					endif lnRelation = 0
		*!*					lnRelation = lnRelation + 1
		*!*					.LoadRelation(laRelations[lnI, 1], laRelations[lnI, 2], ;
		*!*						laRelations[lnI, 3], laRelations[lnI, 4], lcRelationsKey)
		*!*				endif lower(laRelations[lnI, 1]) == lcTable
		*!*			next lnI
			endif tcType = 'Table'
		endwith
		
	ENDPROC

	PROCEDURE loadtree		&& Loads the tree with records from the database
		local laTables[1], ;
			lnTables, ;
			lcKey, ;
			lnI, ;
			lcTable, ;
			laViews[1], ;
			lnViews, ;
			lcView, ;
			laConnections[1], ;
			lnConnections, ;
			lcConnection
		with This
		
		* Add nodes for the database and its properties.
		
			.oTree.Nodes.Add(, 1, 'D', lower(set('DATABASE')), 'Database')
			.LoadProperties('D', 'Database')
		
		* Load tables into the TreeView.
		
			lnTables = adbobjects(laTables, 'Table')
			if lnTables > 0
				asort(laTables)
				lcKey = sys(2015)
				.oTree.Nodes.Add('D', 4, lcKey, 'Tables', 'Table')
				for lnI = 1 to lnTables
					lcTable = laTables[lnI]
					.LoadTable(lcTable, 'Table', lcKey)
				next lnI
			endif lnTables > 0
		
		* Load views into the TreeView.
		
			lnViews = adbobjects(laViews, 'View')
			if lnViews > 0
				asort(laViews)
				lcKey = sys(2015)
				.oTree.Nodes.Add('D', 4, lcKey, 'Views', 'View')
				for lnI = 1 to lnViews
					lcView = laViews[lnI]
					.LoadTable(lcView, 'View', lcKey)
				next lnI
			endif lnViews > 0
		
		* Load connections into the TreeView.
		
			lnConnections = adbobjects(laConnections, 'Connection')
			if lnConnections > 0
				asort(laConnections)
				lcKey = sys(2015)
				.oTree.Nodes.Add('D', 4, lcKey, 'Connections', 'Connection')
				for lnI = 1 to lnConnections
					lcConnection = laConnections[lnI]
					.LoadConnection(lcConnection, lcKey)
				next lnI
			endif lnConnections > 0
		endwith
		
	ENDPROC

	PROCEDURE reversedecimal2hex		&& Converts decimal to hex in reverse order
		lparameters tnValue, ;
			tnPlaces
		local lnDecimal, ;
			lcHex, ;
			lnCurrDecimals, ;
			lnPlaces, ;
			lnI, ;
			lnExponent, ;
			lnTemp
		lnDecimal      = tnValue
		lcHex          = ''
		lnCurrDecimals = set('DECIMALS')
		lnPlaces       = iif(pcount() = 1, 4, tnPlaces)
		set decimals to 17
		for lnI = lnPlaces to 1 step -1
			lnExponent = 256 ^ (lnI - 1)
			lnTemp     = int(lnDecimal/lnExponent)
			lcHex      = lcHex + chr(lnTemp)
			lnDecimal  = lnDecimal - lnTemp * lnExponent
		next lnI
		set decimals to lnCurrDecimals
		return lcHex
		
	ENDPROC

	PROCEDURE reversehex2decimal		&& Converts hex (in reverse order) to decimal
		lparameters tcValue, ;
			tlSigned
		local lnDecimal, ;
			lnLen, ;
			lnI
		lnDecimal = 0
		lnLen     = len(tcValue)
		for lnI = lnLen to 1 step -1
			lnDecimal = lnDecimal + asc(substr(tcValue, lnI, 1)) * 256^(lnLen - lnI)
		next lnI
		if tlSigned
			lnMSB = (lnLen * 8) - 1
			if bittest(lnDecimal, lnMSB)
				lnMax     = 2 ^ (lnMSB + 1)
				lnDecimal = lnDecimal - lnMax
			endif bittest(lnDecimal, lnMSB)
		endif tlSigned
		return lnDecimal
		
	ENDPROC

	PROCEDURE setcurrentproperty		&& Sets the value for the currently selected property
		This.SetProperty(PROPS.ID, alltrim(This.edtValue.Value), ;
			PROPS.BINARY)
		
	ENDPROC

	PROCEDURE setproperty		&& Saves the value for the specified property
		lparameters tnID, ;
			tcValue, ;
			tlBinary
		local lnSelect, ;
			llDone, ;
			lnPos, ;
			llGotProp, ;
			lnValueLen, ;
			lcValue, ;
			lcLength, ;
			lnLength, ;
			lnIDLength, ;
			lnIDCode, ;
			lcCurrValue
		with This
			lnSelect = select()
			select (.cDBCAlias)
		
		* Try to locate the desired property by looking at all properties one at a
		* time until we find it.
		
			llDone     = .F.
			lnPos      = 1
			llGotProp  = .F.
			lcValue    = iif(tlBinary, .ReverseDecimal2Hex(val(tcValue)), tcValue)
			lnValueLen = len(lcValue)
			do while not llDone
		
		* Get the length of this property.
		
				lcLength = substr(PROPERTY, lnPos, 4)
				lnLength = .Hex2Decimal(lcLength)
		
		* Get the length of the property ID.
		
				lcLength   = substr(PROPERTY, lnPos + 4, 2)
				lnIDLength = .Hex2Decimal(lcLength)
		
		* Get the property ID.
		
				lcLength = substr(PROPERTY, lnPos + 6, lnIDLength)
				lnIDCode = .Hex2Decimal(lcLength)
		
		* If this is the property we want, replace the current property value with the
		* new one and flag that we’re done. First check if the value stored is the
		* proper size; if not, we'll have to fix the length.
		
				if lnIDCode = tnID
					lcCurrValue = substr(PROPERTY, lnPos + lnIDLength + 6)
					lcCurrValue = left(lcCurrValue, at(chr(0), lcCurrValue) - 1)
					if not tlBinary and len(lcCurrValue) <> lnLength - lnIDLength - 6
						lnLength = len(lcCurrValue) + lnIDLength + 6 + ;
							iif(tlBinary, 0, 1)
					endif not tlBinary ...
					replace PROPERTY with stuff(PROPERTY, lnPos, lnLength, ;
						.Decimal2Hex(lnValueLen + lnIDLength + 6 + ;
							iif(tlBinary, 0, 1), 4) + ;
						.Decimal2Hex(lnIDLength, 2) + ;
						.Decimal2Hex(tnID, lnIDLength) + ;
						lcValue + iif(tlBinary, '', chr(0)))
					llGotProp = .T.
					llDone    = .T.
		
		* Move the pointer to the next property. If we're out of properties, we're
		* done checking.
		
				else
					lnPos = lnPos + lnLength
					if lnPos > len(PROPERTY)
						llDone = .T.
					endif lnPos > len(PROPERTY)
				endif lnIDCode = tnID
			enddo while not llDone
		
		* If we didn't find the property, let's add it to the end of PROPERTY.
		
			if not llGotProp
				lnIDLength = int(tnID/256) + 1
				replace PROPERTY with PROPERTY + ;
					.Decimal2Hex(lnValueLen + lnIDLength + 6 + ;
						iif(lnValueLen = 1, 0, 1), 4) + ;
					.Decimal2Hex(lnIDLength, 2) + ;
					.Decimal2Hex(tnID, lnIDLength) + ;
					lcValue + iif(lnValueLen = 1, '', chr(0))
			endif not llGotProp
			select (lnSelect)
		endwith
		
	ENDPROC

	PROCEDURE cmdCancel.Click
		Thisform.GetCurrentProperty(Thisform.oTree.SelectedItem)
		
	ENDPROC

	PROCEDURE cmdUpdate.Click
		Thisform.SetCurrentProperty()
		
	ENDPROC

	PROCEDURE lblComment.Init
		This.Caption = ''
		
	ENDPROC

	PROCEDURE oTree.NodeClick
		lparameters toNode
		Thisform.GetCurrentProperty(toNode)
		
	ENDPROC

ENDDEFINE
